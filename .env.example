# OpenAI API key (required for LLM-powered agents)
OPENAI_API_KEY=sk-your-key-here

# Server configuration
REST_HOST=0.0.0.0
REST_PORT=8000
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# Database
DATABASE_PATH=fraud_agent.db

# Scoring thresholds
HIGH_RISK_THRESHOLD=0.8
MEDIUM_RISK_THRESHOLD=0.5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# PII encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
PII_ENCRYPTION_KEY=

# Model configuration
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
